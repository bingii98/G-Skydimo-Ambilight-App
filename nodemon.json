{
  "watch": [
    "main.js",
    "preload.js",
    "connectionManager.js",
    "externalLedManager.js",
    "services/**/*.js",
    "skydimo.js",
    "windowState.js",
    "startupRegistration.js"
  ],
  "ext": "js",
  "ignore": ["node_modules", "src", "dist"],
  "exec": "electron .",
  "env": {
    "NODE_ENV": "development"
  },
  "delay": 300
}
