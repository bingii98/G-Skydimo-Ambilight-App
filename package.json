{
  "name": "skydimo-color",
  "version": "1.2.1",
  "description": "Desktop ambilight app for Skydimo LED strips with screen sync, color control, gradients, animations, and USB auto-detection.",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && nodemon\"",
    "build": "vite build",
    "test": "vitest run",
    "start": "npm run build && cross-env NODE_ENV=production electron .",
    "dev:main": "cross-env NODE_ENV=development nodemon",
    "pack": "npm run icons && npm run build && electron-builder --dir",
    "dist": "npm run icons && npm run build && electron-builder --win",
    "icons": "node scripts/generate-icons.js"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.9",
    "sharp": "^0.33.5",
    "to-ico": "^1.1.5",
    "vite": "^6.0.7",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gskydimo.ambilight",
    "productName": "G Skydimo Ambilight App",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "connectionManager.js",
      "skydimo.js",
      "appInfo.js",
      "appInfo.json",
      "appBehaviorState.js",
      "windowState.js",
      "startupRegistration.js",
      "assets/**/*",
      "services/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/serialport/**/*",
      "**/node_modules/@serialport/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "G Skydimo Ambilight App",
      "menuCategory": "G Skydimo",
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/uninstaller-sidebar.bmp",
      "license": "build/license.html",
      "include": "build/installer.nsh",
      "uninstallDisplayName": "G Skydimo Ambilight App",
      "artifactName": "${productName} Setup ${version}.${ext}"
    }
  },
  "dependencies": {
    "@mantine/core": "^7.16.2",
    "@mantine/hooks": "^7.16.2",
    "@mantine/notifications": "^7.16.2",
    "@tabler/icons-react": "^3.29.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serialport": "^13.0.0"
  }
}
